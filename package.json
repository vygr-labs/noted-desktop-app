{
  "name": "noted",
  "type": "module",
  "version": "1.0.0",
  "description": "A minimal, distraction-free note-taking app",
  "author": "Voyager Technologies Limited",
  "license": "CC-BY-NC-4.0",
  "main": "src/backend/build/main.js",
  "bin": {
    "noted-cli": "cli/build/noted-cli.js"
  },
  "scripts": {
    "prepare": "panda codegen",
    "dev": "astro dev",
    "preview": "astro preview",
    "astro": "astro",
    "frontend:dev": "astro dev",
    "frontend:build": "astro build",
    "backend:build": "tsc -p src/backend && tsc-alias -p ./src/backend/tsconfig.json",
    "cli:build": "tsc -p cli",
    "backend:lint": "eslint src/backend",
    "lint": "prettier -c .",
    "lint:fix": "prettier -w .",
    "boot": "npm run backend:build && electron .",
    "start": "concurrently -k \"npm run frontend:dev\" \"wait-on tcp:127.0.0.1:7241 && npm run boot\"",
    "pre-build": "npm run frontend:build && npm run backend:build",
    "build": "npm run pre-build && electron-builder",
    "build:dir": "npm run pre-build && set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder --dir",
    "build:fast": "set CSC_IDENTITY_AUTO_DISCOVERY=false && npm run pre-build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@ark-ui/solid": "^5.34.1",
    "@astrojs/solid-js": "^6.0.0",
    "@tiptap/core": "^3.20.4",
    "@tiptap/extension-bubble-menu": "^3.20.4",
    "@tiptap/extension-highlight": "^3.20.4",
    "@tiptap/extension-placeholder": "^3.20.4",
    "@tiptap/extension-table": "^3.20.4",
    "@tiptap/extension-table-cell": "^3.20.4",
    "@tiptap/extension-table-header": "^3.20.4",
    "@tiptap/extension-table-row": "^3.20.4",
    "@tiptap/extension-task-item": "^3.20.4",
    "@tiptap/extension-task-list": "^3.20.4",
    "@tiptap/extension-underline": "^3.20.4",
    "@tiptap/pm": "^3.20.4",
    "@tiptap/starter-kit": "^3.20.4",
    "archiver": "^7.0.1",
    "astro": "^6.0.4",
    "astro-relative-links": "^0.4.2",
    "better-sqlite3": "^12.8.0",
    "electron-is-dev": "^3.0.1",
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "lucide-solid": "^0.577.0",
    "solid-icons": "^1.2.0",
    "solid-js": "^1.9.11"
  },
  "devDependencies": {
    "@pandacss/dev": "^1.9.0",
    "@types/archiver": "^7.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@typescript-eslint/parser": "^8.57.0",
    "concurrently": "^9.2.1",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.4"
  },
  "packageManager": "yarn@4.13.0"
}
