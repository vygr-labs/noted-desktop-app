{
  "name": "crater",
  "type": "module",
  "version": "0.5.0",
  "description": "Professional Scripture Projection Software",
  "author": {
    "name": "Eyetu Kingsley",
    "email": "eyetukingsley330@gmail.com",
    "url": "https://eyetukingsley.dev"
  },
  "main": "src/backend/build/main.js",
  "scripts": {
    "dev": "astro dev",
    "preview": "astro preview",
    "astro": "astro",
    "frontend:dev": "astro dev",
    "frontend:build": "astro build",
    "frontend:lint": "eslint pages && eslint components && eslint layouts && eslint utils",
    "backend:build": "tsc -p src/backend && tsc-alias -p ./src/backend/tsconfig.json",
    "backend:lint": "eslint src/backend",
    "lint": "prettier -c . && yarn backend:lint && yarn frontend:lint",
    "lint:fix": "prettier -w .",
    "boot": "yarn backend:build && electron .",
    "start": "concurrently -k \"yarn frontend:dev\" \"wait-on tcp:127.0.0.1:7241 && yarn boot\"",
    "pre-build": "yarn frontend:build && yarn backend:build",
    "build": "yarn pre-build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@ark-ui/solid": "^5.34.1",
    "@astrojs/solid-js": "^5.1.3",
    "astro": "^5.18.1",
    "better-sqlite3": "^12.8.0",
    "electron-is-dev": "^3.0.1",
    "electron-log": "^5.4.3",
    "electron-redux": "^2.0.0",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "fast-safe-stringify": "^2.1.1",
    "fs": "0.0.1-security",
    "lodash": "^4.17.23",
    "mime": "^4.1.0",
    "rtf-parse": "^0.1.0",
    "solid-gesture": "^0.0.3",
    "solid-icons": "^1.2.0",
    "solid-js": "^1.9.11",
    "solid-spring": "^0.0.7"
  },
  "devDependencies": {
    "@pandacss/dev": "^1.9.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.12.0",
    "@typescript-eslint/parser": "^8.57.0",
    "concurrently": "^9.2.1",
    "electron": "^38.8.6",
    "electron-builder": "^26.8.1",
    "electron-devtools-installer": "^4.0.0",
    "eslint": "^9.39.4",
    "prettier": "^3.8.1",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.4"
  }
}
