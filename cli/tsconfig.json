{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "node",
		"rootDir": ".",
		"outDir": "build",
		"esModuleInterop": true,
		"strict": true,
		"skipLibCheck": true,
		"typeRoots": ["./node_modules/@types", "../app/node_modules/@types"],
		"types": ["node", "better-sqlite3"]
	},
	"include": ["*.ts"]
}
